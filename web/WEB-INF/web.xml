<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>TestController</servlet-name>
        <servlet-class>com.stockmanager.controller.TestController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddUserServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.AddUserServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ShowUsersServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.ShowUsersServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteUserServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.DeleteUserServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ShowAddUserFormServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.ShowAddUserFormServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddUserGroupServlet</servlet-name>
        <servlet-class>com.stockmanager.controller.AddUserGroupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ShowUserGroups</servlet-name>
        <servlet-class>com.stockmanager.controller.ShowUserGroupsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddUserServlet</servlet-name>
        <url-pattern>/add-user</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ShowUsersServlet</servlet-name>
        <url-pattern>/show-users</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteUserServlet</servlet-name>
        <url-pattern>/delete-user</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ShowAddUserFormServlet</servlet-name>
        <url-pattern>/add-user-form</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddUserGroupServlet</servlet-name>
        <url-pattern>/add-group</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ShowUserGroups</servlet-name>
        <url-pattern>/user-groups</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
